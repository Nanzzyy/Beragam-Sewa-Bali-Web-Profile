{
  "name": "beragam-sewa-bali-web-profile",
  "version": "1.0.0",
  "description": "Beragam Sewa Bali Web Profile",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "node --watch api/index.js",
    "dev:web:only": "npm run dev --workspace=apps/web",
    "dev:cashflow:only": "npm run dev --workspace=apps/cashflow",
    "dev:dashboard:only": "npm run dev --workspace=apps/dashboard",
    "dev:web": "concurrently -n \"API,WEB\" -c \"blue,green\" \"npm run dev:api\" \"npm run dev:web:only\"",
    "dev:cashflow": "concurrently -n \"API,CASHFLOW\" -c \"blue,yellow\" \"npm run dev:api\" \"npm run dev:cashflow:only\"",
    "dev:dashboard": "concurrently -n \"API,DASHBOARD\" -c \"blue,magenta\" \"npm run dev:api\" \"npm run dev:dashboard:only\"",
    "dev:all": "concurrently -n \"API,WEB,CASHFLOW,DASHBOARD\" -c \"blue,green,yellow,magenta\" \"npm run dev:api\" \"npm run dev:web:only\" \"npm run dev:cashflow:only\" \"npm run dev:dashboard:only\"",
    "dev": "node --watch api/index.js",
    "start": "node api/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "exceljs": "^4.4.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.1.0",
    "file-saver": "^2.0.5",
    "helmet": "^7.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.0"
  }
}
