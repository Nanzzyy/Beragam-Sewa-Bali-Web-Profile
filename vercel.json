{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "home/*.html", "use": "@vercel/static" },
    { "src": "favicon.*", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" },
    { "src": "admin/**", "use": "@vercel/static" },
    { "src": "katalog/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/src/style/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/src/js/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/src/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)\\.html",
      "headers": { "Cache-Control": "public, max-age=0, must-revalidate" },
      "continue": true
    },
    
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/src/(.*)", "dest": "/src/$1" },
    { "src": "/favicon(.*)", "dest": "/favicon$1" },
    
    {
      "src": "/",
      "has": [
        { "type": "host", "value": "admin.beragamsewabali.com" }
      ],
      "dest": "/admin/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        { "type": "host", "value": "admin.beragamsewabali.com" }
      ],
      "dest": "/admin/$1"
    },

    {
      "src": "/",
      "has": [
        { "type": "host", "value": "katalog.beragamsewabali.com" }
      ],
      "dest": "/katalog/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        { "type": "host", "value": "katalog.beragamsewabali.com" }
      ],
      "dest": "/katalog/$1"
    },

    {
      "src": "/",
      "dest": "/home/index.html"
    },
    {
      "src": "/detail\\.html",
      "dest": "/home/detail.html"
    }
  ]
}
