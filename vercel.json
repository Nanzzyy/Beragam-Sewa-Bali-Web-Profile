{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "favicon.*", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" },
    { "src": "admin/**", "use": "@vercel/static" },
    { "src": "katalog/**", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/src/style/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/src/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/src/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/src/:path*",
      "destination": "/src/:path*"
    },
    {
      "source": "/favicon:path*",
      "destination": "/favicon:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "admin.beragamsewabali.com"
        }
      ],
      "destination": "/admin/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "katalog.beragamsewabali.com"
        }
      ],
      "destination": "/katalog/:path*"
    }
  ]
}
