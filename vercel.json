{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "favicon.*", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" },
    { "src": "admin/**", "use": "@vercel/static" },
    { "src": "katalog/**", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/src/style/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/src/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/src/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "admin.beragamsewabali.com"
        }
      ],
      "destination": "/admin/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "katalog.beragamsewabali.com"
        }
      ],
      "destination": "/katalog/:path*"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/src/(.*)", "dest": "/src/$1" },
    { "src": "/admin/(.*)", "dest": "/admin/$1" },
    { "src": "/katalog/(.*)", "dest": "/katalog/$1" },
    { "src": "/favicon\\.ico", "dest": "/favicon.ico" },
    { "src": "/favicon\\.png", "dest": "/favicon.png" },
    { "src": "/detail\\.html", "dest": "/detail.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
