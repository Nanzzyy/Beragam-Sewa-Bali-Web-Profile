{
  "version": 2,
  "redirects": [
    { "source": "/about", "destination": "/#about", "permanent": true },
    { "source": "/contact", "destination": "/#footer", "permanent": true },
    { "source": "/services", "destination": "/#service", "permanent": true },
    { "source": "/products", "destination": "/#package", "permanent": true },
    { "source": "/login", "destination": "https://admin.beragamsewabali.com/", "permanent": true },
    { "source": "/register", "destination": "https://admin.beragamsewabali.com/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "home/*.html", "use": "@vercel/static" },
    { "src": "favicon.*", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" },
    { "src": "admin/**", "use": "@vercel/static" },
    { "src": "katalog/**", "use": "@vercel/static" },
    { "src": "dashboard-build/**", "use": "@vercel/static" },
    { "src": "cashflow-build/**", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/src/style/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/src/js/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/src/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)\\.html",
      "headers": { "Cache-Control": "public, max-age=0, must-revalidate" },
      "continue": true
    },
    
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/src/(.*)", "dest": "/src/$1" },
    { "src": "/favicon(.*)", "dest": "/favicon$1" },
    { "src": "/sitemap\\.xml", "dest": "/sitemap.xml" },
    { "src": "/robots\\.txt", "dest": "/robots.txt" },
    
    {
      "src": "/",
      "has": [
        { "type": "host", "value": "admin.beragamsewabali.com" }
      ],
      "dest": "/admin/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        { "type": "host", "value": "admin.beragamsewabali.com" }
      ],
      "dest": "/admin/$1"
    },

    {
      "src": "/",
      "has": [
        { "type": "host", "value": "katalog.beragamsewabali.com" }
      ],
      "dest": "/katalog/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        { "type": "host", "value": "katalog.beragamsewabali.com" }
      ],
      "dest": "/katalog/$1"
    },

    {
      "src": "/",
      "has": [
        { "type": "host", "value": "dashboard.beragamsewabali.com" }
      ],
      "dest": "/dashboard-build/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        { "type": "host", "value": "dashboard.beragamsewabali.com" }
      ],
      "dest": "/dashboard-build/$1"
    },

    {
      "src": "/",
      "has": [
        { "type": "host", "value": "cashflow.beragamsewabali.com" }
      ],
      "dest": "/cashflow-build/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        { "type": "host", "value": "cashflow.beragamsewabali.com" }
      ],
      "dest": "/cashflow-build/$1"
    },

    {
      "src": "/",
      "dest": "/home/index.html"
    },
    {
      "src": "/detail\\.html",
      "dest": "/home/detail.html"
    }
  ]
}
