<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Detail informasi service dan paket Beragam Sewa Bali">
    <title>Detail — Beragam Sewa Bali</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Tailwind CSS v3 CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-red': '#e63946',
                        'brand-red-dark': '#c1121f',
                        'brand-red-light': '#ff6b6b',
                        'bg-base': '#f7f4f1',
                        'bg-surface': '#ffffff',
                        'bg-elevated': '#f0ece8',
                        'bg-dark': '#1a1a1a',
                        'text-primary': '#1a1a2e',
                        'text-body': '#444455',
                        'text-muted': '#888899',
                    },
                    fontFamily: {
                        outfit: ['Outfit', 'sans-serif'],
                    },
                }
            }
        }
    </script>

    <style type="text/tailwindcss">
        @layer base {
            html { scroll-behavior: smooth; overflow-x: hidden; }
            body { padding-top: 68px; -webkit-font-smoothing: antialiased; }
            ::-webkit-scrollbar { width: 5px; }
            ::-webkit-scrollbar-track { background: theme('colors.bg-base'); }
            ::-webkit-scrollbar-thumb { background: theme('colors.brand-red'); border-radius: 10px; }
            ::-webkit-scrollbar-thumb:hover { background: theme('colors.brand-red-dark'); }
            ::selection { background: theme('colors.brand-red'); color: white; }
        }
        @layer components {
            .reveal {
                @apply opacity-0 translate-y-7 transition-all duration-[550ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)];
            }
            .reveal.visible { @apply opacity-100 translate-y-0; }
            .reveal-delay-1 { @apply delay-100; }
            .reveal-delay-2 { @apply delay-[220ms]; }

            /* Navbar glass */
            #mainNavbar {
                @apply bg-[#f7f4f1bf] backdrop-blur-md backdrop-saturate-150 border-b border-transparent shadow-none transition-all duration-300;
            }
            #mainNavbar.scrolled {
                @apply bg-[#f7f4f1f7] border-black/8 shadow-sm;
            }

            /* DETAIL HERO */
            .detail-hero {
                @apply relative h-[280px] sm:h-[380px] overflow-hidden mt-0 flex items-end;
            }
            .detail-hero-bg {
                @apply absolute inset-0 bg-cover bg-center bg-[#333] scale-105 transition-transform duration-[8s] ease-out blur-[2px];
            }
            .detail-hero:hover .detail-hero-bg {
                @apply scale-100;
            }
            .detail-hero-overlay {
                @apply absolute inset-0;
                background: linear-gradient(to bottom, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.75) 100%);
            }
            .detail-hero-content {
                @apply relative z-[5] pb-14 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto w-full;
            }
            .detail-hero-title {
                @apply text-white font-extrabold tracking-tight mt-2 leading-tight min-h-[1.3em];
                font-size: clamp(1.5rem, 5vw, 2.6rem);
                text-shadow: 0 3px 20px rgba(0, 0, 0, 0.6);
            }
            .detail-hero-wave {
                @apply absolute -bottom-[1px] left-0 w-full h-[60px] bg-bg-base z-[4] pointer-events-none;
                clip-path: ellipse(55% 100% at 50% 100%);
            }

            .detail-back-btn {
                @apply inline-flex items-center gap-2 text-white/75 no-underline text-[0.85rem] font-medium tracking-wide py-[0.35rem] px-[0.7rem] rounded-full border border-white/25 backdrop-blur-[6px] mb-4 transition-all duration-200 hover:bg-white/15 hover:text-white hover:gap-3;
            }
            .detail-badge {
                @apply inline-block bg-brand-red text-white text-[0.72rem] font-bold uppercase tracking-widest py-[0.28rem] px-[0.75rem] rounded-full mb-2.5 shadow-[0_4px_14px_rgba(230,57,70,0.18)];
            }

            /* MAIN */
            .detail-main {
                @apply max-w-[820px] mx-auto px-4 sm:px-6 py-6 sm:py-8 pb-20;
            }

            /* CARDS */
            .detail-section-card {
                @apply bg-bg-surface border border-black/8 rounded-xl sm:rounded-2xl p-5 sm:p-7 mb-5 shadow-sm transition-shadow duration-300 hover:shadow-md;
            }
            .detail-section-heading {
                @apply text-[0.8rem] font-bold uppercase tracking-widest text-text-muted mb-4 flex items-center gap-2;
            }
            .detail-section-heading .fa {
                @apply text-brand-red;
            }
            .detail-desc {
                @apply text-text-body text-base leading-relaxed whitespace-pre-wrap;
            }

            /* INFO GRID */
            .detail-info-grid {
                @apply grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5;
            }
            .detail-info-item {
                @apply bg-bg-surface border border-black/8 rounded-[14px] p-[1.1rem] flex items-start gap-[0.85rem] transition-all duration-200 hover:border-brand-red/30 hover:shadow-[0_8px_30px_rgba(230,57,70,0.08)];
            }
            .detail-info-icon {
                @apply text-brand-red text-[1.15rem] mt-[2px] shrink-0;
            }
            .detail-info-label {
                @apply block text-[0.72rem] font-bold uppercase tracking-wide text-text-muted mb-1;
            }
            .detail-info-value {
                @apply block text-[0.92rem] font-semibold text-text-primary;
            }

            /* CTA SECTION */
            .detail-cta-section {
                @apply rounded-xl sm:rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 relative overflow-hidden shadow-lg shadow-brand-red/20;
                background: linear-gradient(135deg, theme('colors.brand-red') 0%, theme('colors.brand-red-dark') 100%);
            }
            .detail-cta-section::before {
                content: '';
                @apply absolute -right-10 -top-10 w-40 h-40 bg-white/10 rounded-full;
            }
            .detail-cta-section::after {
                content: '';
                @apply absolute right-[60px] -bottom-[60px] w-[120px] h-[120px] bg-white/5 rounded-full;
            }
            .detail-cta-text {
                @apply relative z-[1];
            }
            .detail-cta-text h3 {
                @apply text-white text-[1.2rem] font-bold mb-1;
            }
            .detail-cta-text p {
                @apply text-white/80 text-[0.9rem] m-0;
            }
            .detail-cta-btn {
                @apply inline-flex items-center justify-center sm:justify-start gap-2.5 bg-white text-brand-red no-underline font-bold text-[0.95rem] py-[0.7rem] px-[1.6rem] rounded-lg shadow-md relative z-[1] transition-all duration-200 hover:bg-[#f2ede8] hover:-translate-y-0.5 hover:shadow-lg whitespace-nowrap shrink-0 w-full sm:w-auto;
            }

            /* ERROR */
            .detail-error {
                @apply text-center py-20 px-4;
                animation: fade-in-up 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
            }
            .detail-error-icon-wrap {
                @apply w-[72px] h-[72px] rounded-full bg-brand-red/5 border-2 border-brand-red/30 flex items-center justify-center mx-auto mb-5 text-[1.8rem] text-brand-red;
            }
            .detail-error-title {
                @apply text-[1.5rem] font-bold text-text-primary mb-2;
            }
            .detail-error-msg {
                @apply text-text-muted mb-8;
            }
            .detail-error .detail-cta-btn {
                @apply bg-brand-red text-white hover:bg-brand-red-dark hover:text-white w-auto;
            }

            /* FOOTER */
            .detail-footer {
                @apply bg-bg-dark border-t border-white/10 py-[1.4rem] font-outfit;
            }
            .detail-footer-inner {
                @apply flex flex-col sm:flex-row items-center justify-between gap-2 text-white/35 text-[0.8rem] text-center max-w-7xl mx-auto px-4;
            }

            /* SKELETON */
            .skeleton-title,
            .skeleton-inline,
            .skeleton-line,
            .skeleton-chip {
                background: linear-gradient(90deg, #e5e0db 25%, #f0ece8 50%, #e5e0db 75%);
                background-size: 600px 100%;
                animation: shimmer 1.6s infinite linear;
                @apply rounded-md;
            }
            .skeleton-line { @apply h-4 w-full mb-2.5; }
            .skeleton-chip { @apply h-8 w-[100px] rounded-full inline-block; }
            
            #detail-hero .skeleton-title {
                background: linear-gradient(90deg, rgba(255, 255, 255, 0.1) 25%, rgba(255, 255, 255, 0.2) 50%, rgba(255, 255, 255, 0.1) 75%);
                background-size: 600px 100%;
            }

        }
    </style>
    <style>
        @keyframes shimmer {
            0% { background-position: -600px 0; }
            100% { background-position: 600px 0; }
        }
        @keyframes fade-in-up {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in-up { animation: fade-in-up 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both; }
    </style>
</head>

<body class="font-outfit bg-bg-base text-text-body overflow-x-hidden detail-page">

    <!-- ======= Navbar ======= -->
    <nav id="mainNavbar"
        class="fixed top-0 left-0 right-0 z-50 w-full px-4 py-3 transition-all duration-300">
        <div class="max-w-7xl mx-auto flex items-center justify-between">

            <!-- Brand -->
            <a href="/"
                class="flex items-center gap-2 text-text-primary font-bold text-base no-underline">
                <img src="./src/assets/images/logos.png" alt="Logo" width="30" height="30">
                <span class="hidden sm:inline">Beragam Sewa Bali</span>
                <span class="sm:hidden">BSB</span>
            </a>

            <!-- Desktop Nav -->
            <div class="hidden lg:flex items-center gap-6" id="desktopNavDetail">
                <a href="/" class="text-text-body text-sm font-medium hover:text-brand-red transition-colors">Home</a>
                <a href="/#about" class="text-text-body text-sm font-medium hover:text-brand-red transition-colors">About</a>

                <!-- Dropdown -->
                <div class="relative group">
                    <button class="flex items-center gap-1 text-text-body text-sm font-medium hover:text-brand-red transition-colors">
                        Service & Package
                        <i class="fa fa-chevron-down text-xs ml-1 transition-transform group-hover:rotate-180 duration-200"></i>
                    </button>
                    <div class="absolute top-full left-0 mt-2 w-44 bg-bg-surface rounded-xl shadow-lg border border-black/8 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                        <a href="/#service" class="block px-4 py-2 text-sm text-text-body hover:text-brand-red hover:bg-red-50 rounded-lg mx-1 transition-colors">Service</a>
                        <a href="/#package" class="block px-4 py-2 text-sm text-text-body hover:text-brand-red hover:bg-red-50 rounded-lg mx-1 transition-colors">Package</a>
                    </div>
                </div>

                <a href="/#gallery" class="text-text-body text-sm font-medium hover:text-brand-red transition-colors">Gallery</a>

                <a href="#" class="flex items-center gap-2 border border-brand-red/30 text-text-primary px-4 py-1.5 rounded-lg text-sm font-semibold hover:bg-brand-red hover:text-white hover:border-brand-red transition-all duration-200">
                    <img class="icon" src="https://img.icons8.com/?size=100&id=78382&format=png&color=000000" alt="" width="18" height="18">
                    Contact
                </a>
            </div>

            <!-- Mobile Toggler -->
            <button id="mobileMenuBtn" class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg border border-brand-red/30 text-text-primary hover:bg-brand-red/5 transition-colors"
                type="button"
                aria-label="Toggle navigation">
                <i class="fa fa-bars text-lg"></i>
            </button>
        </div>
    </nav>

    <!-- Mobile Offcanvas (Tailwind Custom) -->
    <div id="mobileMenu" class="fixed inset-0 z-[60] invisible">
        <!-- Backdrop -->
        <div id="mobileMenuBackdrop" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
        <!-- Sidebar -->
        <div id="mobileMenuSidebar" class="absolute top-0 right-0 bottom-0 w-[280px] bg-bg-surface border-l border-black/8 shadow-2xl translate-x-full transition-transform duration-300 flex flex-col">
            <div class="flex items-center justify-between p-5 border-b border-black/8">
                <h5 class="text-text-primary font-bold font-outfit text-base">Beragam Sewa Bali</h5>
                <button type="button" id="closeMobileMenuBtn" class="text-text-muted hover:text-brand-red text-xl leading-none transition-colors">
                    <i class="fa fa-times"></i>
                </button>
            </div>
            <div class="flex flex-col py-2 flex-grow">
                <nav class="flex flex-col w-full">
                    <a href="/" class="mobile-nav-link block px-6 py-3.5 text-text-primary text-[0.95rem] font-medium border-b border-black/8 hover:bg-bg-base hover:text-brand-red transition-colors">Home</a>
                    <a href="/#about" class="mobile-nav-link block px-6 py-3.5 text-text-primary text-[0.95rem] font-medium border-b border-black/8 hover:bg-bg-base hover:text-brand-red transition-colors">About</a>
                    <a href="/#service" class="mobile-nav-link block px-6 py-3.5 text-text-primary text-[0.95rem] font-medium border-b border-black/8 hover:bg-bg-base hover:text-brand-red transition-colors">Service</a>
                    <a href="/#package" class="mobile-nav-link block px-6 py-3.5 text-text-primary text-[0.95rem] font-medium border-b border-black/8 hover:bg-bg-base hover:text-brand-red transition-colors">Package</a>
                    <a href="/#gallery" class="mobile-nav-link block px-6 py-3.5 text-text-primary text-[0.95rem] font-medium border-b border-black/8 hover:bg-bg-base hover:text-brand-red transition-colors">Gallery</a>
                </nav>
                <div class="p-6 mt-auto">
                    <a href="#" class="mobile-nav-link group flex items-center justify-center gap-2 w-full py-2.5 border-2 border-brand-red rounded-full text-brand-red font-semibold text-sm hover:bg-brand-red hover:text-white transition-colors">
                        <img src="https://img.icons8.com/?size=100&id=78382&format=png&color=e63946" alt="" width="18" height="18" class="group-hover:brightness-0 group-hover:invert transition-all">
                        Contact
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ======= Hero Banner ======= -->
    <div class="detail-hero" id="detail-hero">
        <div class="detail-hero-bg" id="detail-hero-bg"></div>
        <div class="detail-hero-overlay"></div>
        <div class="detail-hero-content container">
            <a href="javascript:history.back()" class="detail-back-btn">
                <i class="fa fa-arrow-left"></i> Kembali
            </a>
            <span id="detail-badge" class="detail-badge" style="display:none;"></span>
            <h1 id="detail-title" class="detail-hero-title">
                <span class="skeleton-title skeleton-inline" style="width:60%;height:44px;display:block;"></span>
            </h1>
        </div>
        <div class="detail-hero-wave"></div>
    </div>

    <!-- ======= Main Content ======= -->
    <main class="detail-main container">

        <!-- Skeleton -->
        <div id="detail-skeleton" class="detail-skeleton-body">
            <div class="skeleton-section">
                <div class="skeleton-line" style="width:80%;height:18px;"></div>
                <div class="skeleton-line" style="width:95%;"></div>
                <div class="skeleton-line" style="width:88%;"></div>
                <div class="skeleton-line" style="width:70%;"></div>
            </div>
            <div class="skeleton-section">
                <div class="skeleton-line" style="width:50%;height:22px;"></div>
                <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:.5rem;">
                    <div class="skeleton-chip"></div>
                    <div class="skeleton-chip"></div>
                    <div class="skeleton-chip"></div>
                </div>
            </div>
        </div>

        <!-- Content -->
        <div id="detail-content" style="display:none;">

            <!-- Description card -->
            <div class="detail-section-card reveal">
                <h2 class="detail-section-heading">
                    <i class="fa fa-align-left"></i> Deskripsi
                </h2>
                <div id="detail-desc" class="detail-desc"></div>
            </div>

            <!-- Info grid -->
            <div class="detail-info-grid reveal reveal-delay-1">
                <div class="detail-info-item">
                    <i class="fa fa-map-marker detail-info-icon"></i>
                    <div>
                        <span class="detail-info-label">Lokasi</span>
                        <span class="detail-info-value">Bali, Indonesia</span>
                    </div>
                </div>
                <div class="detail-info-item">
                    <i class="fa fa-clock-o detail-info-icon"></i>
                    <div>
                        <span class="detail-info-label">Jam Operasional</span>
                        <span class="detail-info-value">Senin - Minggu, 08.00 - 22.00</span>
                    </div>
                </div>
                <div class="detail-info-item">
                    <i class="fa fa-check-circle detail-info-icon"></i>
                    <div>
                        <span class="detail-info-label">Status</span>
                        <span class="detail-info-value">Tersedia</span>
                    </div>
                </div>
            </div>

            <!-- CTA section -->
            <div class="detail-cta-section reveal reveal-delay-2">
                <div class="detail-cta-text">
                    <h3>Tertarik? Hubungi kami sekarang</h3>
                    <p>Tim kami siap membantu kamu mendapatkan penawaran terbaik.</p>
                </div>
                <a id="detail-wa-btn" href="#" class="detail-cta-btn" target="_blank" rel="noopener">
                    <i class="fa fa-whatsapp"></i>
                    Hubungi via WhatsApp
                </a>
            </div>

        </div>

        <!-- Error State -->
        <div id="detail-error" class="detail-error" style="display:none;">
            <div class="detail-error-icon-wrap">
                <i class="fa fa-exclamation-triangle"></i>
            </div>
            <h2 class="detail-error-title">Data Tidak Ditemukan</h2>
            <p class="detail-error-msg">Item yang kamu cari tidak tersedia atau sudah dihapus.</p>
            <a href="/" class="detail-cta-btn">
                <i class="fa fa-home"></i> Kembali ke Beranda
            </a>
        </div>

    </main>

    <!-- ======= Footer ======= -->
    <footer class="detail-footer">
        <div class="container detail-footer-inner">
            <span>&copy; <span id="footer-year"></span> Beragam Sewa Bali. All rights reserved.</span>
            <span>Made with <i class="fa fa-heart" style="color:#e63946;"></i> in Bali</span>
        </div>
    </footer>

    <script>document.getElementById('footer-year').textContent = new Date().getFullYear();</script>


    <script src="./src/js/detail.js"></script>
</body>

</html>