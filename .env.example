# =============================================
# Beragam Sewa Bali — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# =============================================

# Server
PORT=3000

# Database & Storage Supabase
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_public_key_here

# Session Secret (gunakan string acak panjang, minimal 32 karakter)
# Generate di terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti_dengan_string_acak_panjang_minimal_32_karakter

# Admin Password (bcrypt hash dari password admin)
# Cara generate hash: node scripts/generate-hash.js
# Contoh password: Admin@Bali2025 (JANGAN gunakan ini di production!)
ADMIN_PASSWORD_HASH=

# CORS — domain frontend yang diizinkan (pisahkan dengan koma jika lebih dari satu)
# Development: http://localhost:3000
# Production: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000
