# === LOCAL DEVELOPMENT (default) ===
# Point ke stack Supabase Docker lokal. Lihat dev-doc/LOCAL-DEV.md.
# Copy ke .env.local lalu isi ANON_KEY lokal (dari utils/generate-keys.sh).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8001
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key_here

# === PRODUCTION (Coolify) ===
# Dipakai saat deploy, di-set di Coolify Environment Variables tab (timpa .env.local).
# NEXT_PUBLIC_SUPABASE_URL=https://api.beragamsewabali.com
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
